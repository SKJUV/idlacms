# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Appwrite Configurations
VITE_APPWRITE_PROJECT_ID="6a44f36c002ed43aca9a"
VITE_APPWRITE_PROJECT_NAME="IDLA"
VITE_APPWRITE_ENDPOINT="https://fra.cloud.appwrite.io/v1"

# Database & Storage Configuration — remplies automatiquement après
# `npm run appwrite:setup` (voir scripts/setup-appwrite.ts)
VITE_APPWRITE_DATABASE_ID="idla_cms"
VITE_APPWRITE_COLLECTION_PROGRAMS="programs"
VITE_APPWRITE_COLLECTION_APPLICATIONS="applications"
VITE_APPWRITE_COLLECTION_LOGS="activity_logs"
VITE_APPWRITE_COLLECTION_NEWS="news"
VITE_APPWRITE_COLLECTION_TESTIMONIALS="testimonials"
VITE_APPWRITE_COLLECTION_CMS_USERS="cms_users"
VITE_APPWRITE_COLLECTION_CANDIDATE_DOCUMENTS="candidate_documents"
VITE_APPWRITE_COLLECTION_MESSAGES="messages"
VITE_APPWRITE_BUCKET_DOCUMENTS="documents"

# Server-side uniquement — NE JAMAIS préfixer par VITE_ (serait exposé au navigateur).
# Requis uniquement pour exécuter `npm run appwrite:setup`.
# Créez cette clé API dans Console Appwrite > votre projet > Overview > Integrate > API Keys,
# avec les scopes (lecture ET écriture, le script liste l'existant pour rester idempotent) :
# databases.read, databases.write, collections.read, collections.write,
# attributes.read, attributes.write, indexes.read, indexes.write,
# documents.read, documents.write, files.read, files.write,
# buckets.read, buckets.write, teams.read, teams.write, users.read, users.write.
APPWRITE_API_KEY=""

